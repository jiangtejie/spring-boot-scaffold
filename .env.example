# ============================================
# Spring Boot Scaffold — 环境变量模板
# 复制为 .env 并修改值（.env 文件不纳入版本管理）
# ============================================

# 服务端口
SERVER_PORT=8080

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=scaffold
DB_USERNAME=root
DB_PASSWORD=root

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# 文件上传目录 & 访问前缀
UPLOAD_DIR=./uploads
UPLOAD_BASE_URL=http://localhost:8080/uploads

# 外部 API HMAC 签名密钥（必填，缺省为空时签名校验不通过）
EXTERNAL_API_SECRET=change-me-to-a-random-string
